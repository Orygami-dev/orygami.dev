---
const reasons = [
  {
    title: 'Écoute attentive',
    description: 'Je prends le temps de comprendre votre activité, vos valeurs et vos objectifs pour créer un site qui vous ressemble.',
  },
  {
    title: 'Design soigné',
    description: 'Chaque détail compte. Je conçois des interfaces élégantes et intuitives qui inspirent confiance à vos visiteurs.',
  },
  {
    title: 'Approche personnalisée',
    description: 'Pas de templates génériques. Votre site est conçu sur-mesure pour répondre précisément à vos besoins.',
  },
  {
    title: 'Accompagnement durable',
    description: 'Je reste disponible après la livraison pour vous accompagner dans l\'évolution de votre présence en ligne.',
  },
];
---

<section id="pourquoi" class="why-me">
  <div class="why-me__container">
    <div class="why-me__header">
      <h2 class="why-me__title" data-reveal="up">Pourquoi travailler avec moi ?</h2>
      <p class="why-me__intro" data-reveal="up" data-reveal-delay="1">
        Au-delà des compétences techniques, c'est une collaboration basée sur l'écoute et la confiance que je vous propose.
      </p>
    </div>

    <div class="why-me__grid">
      {reasons.map((reason, index) => (
        <div class="reason-item" data-reveal="fade" data-reveal-delay={String((index % 2) + 1)}>
          <span class="reason-item__number">{String(index + 1).padStart(2, '0')}</span>
          <h3 class="reason-item__title">{reason.title}</h3>
          <p class="reason-item__description">{reason.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .why-me {
    @include section;
    background:
      radial-gradient(circle, rgba($primary, 0.08) 1px, transparent 1px) 0 0 / 24px 24px,
      white;

    &__container {
      @include container;
    }

    &__header {
      text-align: center;
      max-width: 600px;
      margin: 0 auto 4rem;
    }

    &__title {
      font-family: 'Caveat', cursive;
      font-size: 2.5rem;
      margin-bottom: 1rem;

      @include md {
        font-size: 3rem;
      }
    }

    &__intro {
      color: $text-light;
      font-size: 1.125rem;
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;

      @include md {
        grid-template-columns: repeat(2, 1fr);
        gap: 3rem 2.5rem;
      }
    }
  }

  .reason-item {
    text-align: left;
    padding: 1.5rem;

    &:nth-child(1) { transform: rotate(-1deg); }
    &:nth-child(2) {
      transform: rotate(0.5deg);
      @include md { margin-top: 2rem; }
    }
    &:nth-child(3) {
      transform: rotate(-0.5deg);
      @include md { margin-top: -1rem; }
    }
    &:nth-child(4) { transform: rotate(1deg); }

    &__number {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      font-family: 'Caveat', cursive;
      font-size: 2.5rem;
      font-weight: 700;
      color: $primary;
      border: 2.5px solid $primary;
      border-radius: 50%;
      transform: rotate(-3deg);
      margin-bottom: 1rem;
    }

    &__title {
      font-family: 'Caveat', cursive;
      font-size: 1.6rem;
      margin-bottom: 0.75rem;
      text-decoration: underline wavy $primary;
      text-underline-offset: 4px;
      text-decoration-thickness: 1.5px;
    }

    &__description {
      font-size: 0.9rem;
      color: $text-light;
      line-height: 1.6;
    }
  }
</style>
