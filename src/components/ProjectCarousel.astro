---
import { projects } from '../data/projects';

const rotations = ['-1.2deg', '0.8deg', '-0.6deg', '1.1deg'];
---

<section id="portfolio" class="portfolio">
  <div class="portfolio__container">
    <div class="portfolio__header">
      <h2 class="portfolio__title" data-reveal="up">Mes réalisations</h2>
      <p class="portfolio__intro" data-reveal="up" data-reveal-delay="1">
        Découvrez quelques projets sur lesquels j'ai eu le plaisir de travailler.
      </p>
    </div>

    <div class="portfolio__grid">
      {projects.map((project, i) => (
        <a
          href={`/realisations/${project.id}`}
          class="dossier"
          data-reveal="fade"
          data-reveal-delay={String((i % 2) + 1)}
          style={`--rotation: ${rotations[i]};`}
        >
          <div class="dossier__tab">
            <span class="dossier__category">{project.category}</span>
          </div>
          <div class="dossier__body">
            <div class="dossier__cover">
              <div class="dossier__image">
                <div class="dossier__placeholder" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);">
                  <span class="dossier__placeholder-letter">{project.title.charAt(0)}</span>
                </div>
              </div>
              <h3 class="dossier__title">{project.title}</h3>
            </div>
            <div class="dossier__inside">
              <p class="dossier__description">{project.description}</p>
              <span class="dossier__cta">
                Ouvrir le dossier
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .portfolio {
    @include section;
    background: transparent;
    --primary: #{$primary};
    --primary-dark: #{$primary-dark};

    &__container {
      @include container;
    }

    &__header {
      text-align: center;
      max-width: 600px;
      margin: 0 auto 4rem;
    }

    &__title {
      font-family: 'Caveat', cursive;
      font-size: 2.5rem;
      margin-bottom: 1rem;

      @include md {
        font-size: 3rem;
      }
    }

    &__intro {
      color: $text-light;
      font-size: 1.125rem;
    }

    &__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      perspective: 1200px;

      @include md {
        grid-template-columns: repeat(2, 1fr);
        gap: 3rem 2.5rem;
      }
    }
  }

  .dossier {
    text-decoration: none;
    color: inherit;
    display: block;
    position: relative;
    transform: rotate(var(--rotation, 0deg));
    transition: transform 0.4s ease, z-index 0s;

    @include md {
      &:nth-child(2) { margin-top: 2rem; }
      &:nth-child(3) { margin-top: -1rem; }
    }

    &:hover,
    &:focus-within,
    &.is-open {
      transform: rotate(0deg) scale(1.02);
      z-index: 2;

      .dossier__cover {
        transform: rotateX(-15deg) translateY(-8px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
      }

      .dossier__inside {
        opacity: 1;
        transform: translateY(0);
      }

      .dossier__tab {
        background: $primary;
        color: white;
      }
    }

    &__tab {
      display: inline-block;
      background: #E1E7E5;
      padding: 0.3rem 1.2rem;
      border-radius: 6px 6px 0 0;
      margin-left: 1.5rem;
      font-family: 'Caveat', cursive;
      font-size: 1rem;
      font-weight: 700;
      color: $text;
      transition: background 0.3s ease, color 0.3s ease;
      transform: translateY(2px);
    }

    &__body {
      position: relative;
      background: #FFFDF7;
      border-radius: 2px 8px 4px 4px;
      box-shadow: 2px 4px 12px rgba(0, 0, 0, 0.1);
      min-height: 280px;

      &::before {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 3px,
          rgba(0, 0, 0, 0.015) 3px,
          rgba(0, 0, 0, 0.015) 4px
        );
        pointer-events: none;
        z-index: 1;
        border-radius: inherit;
      }
    }

    &__cover {
      position: relative;
      z-index: 2;
      padding: 1.5rem;
      transform-origin: top center;
      transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1),
                  box-shadow 0.5s ease;
      background: #FFFDF7;
      border-radius: 2px 8px 4px 4px;
    }

    &__image {
      aspect-ratio: 16 / 9;
      border-radius: 2px;
      overflow: hidden;
      margin-bottom: 1rem;
      box-shadow: 1px 2px 4px rgba(0, 0, 0, 0.08);
    }

    &__placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    &__placeholder-letter {
      font-family: 'Caveat', cursive;
      font-size: 3.5rem;
      font-weight: 700;
      color: rgba(white, 0.3);
    }

    &__title {
      font-family: 'Caveat', cursive;
      font-size: 1.6rem;
      color: $text;
    }

    &__inside {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1.5rem;
      padding-top: 0.5rem;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.4s ease 0.1s, transform 0.4s ease 0.1s;
      z-index: 0;
    }

    &__description {
      font-size: 0.9rem;
      color: $text-light;
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    &__cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: 'Caveat', cursive;
      font-size: 1.15rem;
      font-weight: 700;
      color: $primary-dark;

      svg {
        width: 16px;
        height: 16px;
        transition: transform 0.3s ease;
      }
    }

    &:hover .dossier__cta svg,
    &:focus-within .dossier__cta svg,
    &.is-open .dossier__cta svg {
      transform: translateX(4px);
    }
  }
</style>

<script>
  if ('ontouchstart' in window) {
    const dossiers = document.querySelectorAll('.dossier');
    dossiers.forEach((dossier) => {
      dossier.addEventListener('click', (e) => {
        if (dossier.classList.contains('is-open')) return;
        e.preventDefault();
        dossiers.forEach((d) => d.classList.remove('is-open'));
        dossier.classList.add('is-open');
      });
    });
  }
</script>
